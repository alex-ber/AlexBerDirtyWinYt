# ----------------------------------
# Environments (CRITICAL)
# ----------------------------------
.env
.env.*
.venv*
venv*
env/
ENV/
env.bak/
virtualenv/
node_modules/

# ----------------------------------
# Secrets (CRITICAL)
# ----------------------------------
.secrets/
credentials.json
*.pem
*.key

# ----------------------------------
# Python Artifacts
# ----------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# ----------------------------------
# Packaging / build
# ----------------------------------
build/
dist/
*.egg-info/
*.egg
*.whl
*.tar.gz

# ----------------------------------
# Logs
# ----------------------------------
*.log

# ----------------------------------
# Audio artifacts (Whisper pipeline)
# ----------------------------------
*.wav
*.mp3
*.m4a
*.flac

# Chunked audio
*part*.wav
chunk_*.wav

# ----------------------------------
# Transcription outputs
# ----------------------------------
full_transcript.txt
*.srt
*.vtt
*.json

# ----------------------------------
# Data artifacts
# ----------------------------------
*.pkl
*.bin
.ipynb_checkpoints/

# ----------------------------------
# IDE / OS noise
# ----------------------------------
.idea/
.vscode/
*.kdev4
.DS_Store
Thumbs.db
*~
*.swp
*.swo

# ----------------------------------
# Testing / tooling
# ----------------------------------
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
.tox/

# ----------------------------------
# Local working folders / scratch
# ----------------------------------
downloaded/
prof/
scratch/

# ----------------------------------
# Optional: ignore binaries entirely
# (disable LFS usage if uncommented)
# ----------------------------------
# app/*.exe
# app/*.dll

# ----------------------------------
# Allow scripts explicitly
# ----------------------------------
!*.bat
!*.sh
