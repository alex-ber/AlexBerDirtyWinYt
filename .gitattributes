# ----------------------------------
# Default: normalize to LF (Linux/Docker safe)
# ----------------------------------
* text=auto eol=lf
# ----------------------------------
# Windows scripts (CRLF required)
# ----------------------------------
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
# ----------------------------------
# Code / scripts (LF required)
# ----------------------------------
*.py text eol=lf
*.sh text eol=lf
# ----------------------------------
# Text / config (LF)
# ----------------------------------
*.txt   text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.ini   text eol=lf
*.cfg   text eol=lf
*.conf  text eol=lf
# ----------------------------------
# Docker (future-proof)
# ----------------------------------
Dockerfile text eol=lf
*.dockerfile text eol=lf
.dockerignore text eol=lf
# ----------------------------------
# Binary files (never modified)
# ----------------------------------
*.exe binary
*.dll binary
*.zip binary
*.7z  binary
*.tar binary
*.gz  binary
*.wav binary
*.mp3 binary
*.flac binary
*.m4a binary
*.db binary
*.sqlite binary
app/*.exe filter=lfs diff=lfs merge=lfs -text
app/*.dll filter=lfs diff=lfs merge=lfs -text
