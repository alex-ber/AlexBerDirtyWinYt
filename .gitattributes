# ----------------------------------
# Windows scripts (CRLF required)
# ----------------------------------
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# ----------------------------------
# Code / Shell scripts (LF required)
# ----------------------------------
*.sh text eol=lf
*.py text eol=lf

# ----------------------------------
# Text / Config / Explicit text (LF)
# ----------------------------------
*.txt   text eol=lf
*.md    text eol=lf
*.toml  text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.ini   text eol=lf
*.cfg   text eol=lf
*.conf  text eol=lf

# ----------------------------------
# Docker (must be LF)
# ----------------------------------
Dockerfile    text eol=lf
*.dockerfile  text eol=lf
.dockerignore text eol=lf

# ----------------------------------
# Binary (never normalized or diffed)
# ----------------------------------
# Executables & Libraries
*.exe binary
*.dll binary
*.so  binary

# Images
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary

# Audio
*.wav  binary
*.mp3  binary
*.flac binary
*.m4a  binary

# Archives
*.zip binary
*.7z  binary
*.tar binary
*.gz  binary

# Databases
*.db     binary
*.sqlite binary

# ----------------------------------
# Git LFS (large Windows binaries)
# ----------------------------------
app/*.exe filter=lfs diff=lfs merge=lfs -text
app/*.dll filter=lfs diff=lfs merge=lfs -text
