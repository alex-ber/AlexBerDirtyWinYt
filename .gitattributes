# ----------------------------------
# Default: normalize to LF (Linux/Docker safe)
# ----------------------------------
* text=auto eol=lf

# ----------------------------------
# Windows scripts (CRLF required)
# ----------------------------------
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# ----------------------------------
# Code / scripts (LF required)
# ----------------------------------
*.py text eol=lf
*.sh text eol=lf

# ----------------------------------
# Text / config (LF)
# ----------------------------------
*.txt   text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.ini   text eol=lf
*.cfg   text eol=lf
*.conf  text eol=lf

# ----------------------------------
# Docker (must be LF)
# ----------------------------------
Dockerfile text eol=lf
*.dockerfile text eol=lf
.dockerignore text eol=lf

# ----------------------------------
# Binary files (never normalized)
# ----------------------------------
*.exe -text
*.dll -text
*.zip -text
*.7z  -text
*.tar -text
*.gz  -text

*.wav -text
*.mp3 -text
*.flac -text
*.m4a -text

*.db -text
*.sqlite -text

# ----------------------------------
# Git LFS (large Windows binaries)
# ----------------------------------
app/*.exe filter=lfs diff=lfs merge=lfs -text
app/*.dll filter=lfs diff=lfs merge=lfs -text